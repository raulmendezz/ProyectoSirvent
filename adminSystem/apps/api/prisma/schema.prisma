generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs   Log[]
  alerts Alert[]
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  description String?  @db.Text
  stock       Int      @default(0)
  minStock    Int      @default(5)
  price       Decimal  @db.Decimal(10, 2)
  asin        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  alerts Alert[]
}

model Log {
  id        Int      @id @default(autoincrement())
  level     LogLevel
  source    String
  message   String   @db.Text
  meta      Json?
  userId    Int?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Alert {
  id        Int         @id @default(autoincrement())
  type      AlertType
  message   String
  resolved  Boolean     @default(false)
  productId Int?
  userId    Int?
  createdAt DateTime    @default(now())

  product Product? @relation(fields: [productId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum AlertType {
  LOW_STOCK
  AMAZON_ERROR
  LOGIN_FAILED
  WORKER_ERROR
}

model IpWhitelistEntry {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  label     String?
  createdAt DateTime @default(now())
}
