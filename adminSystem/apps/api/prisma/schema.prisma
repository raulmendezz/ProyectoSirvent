generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique(map: "User_email_key")
  password  String
  role      user_role @default(VIEWER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())

  @@map("user")
}

// ── Logs ──────────────────────────────────────────────────────────────────────

model Log {
  id        Int       @id @default(autoincrement())
  level     log_level
  source    String
  message   String    @db.Text
  meta      String?   @db.LongText
  userId    Int?
  createdAt DateTime  @default(now())

  @@map("log")
}

// ── Alerts ────────────────────────────────────────────────────────────────────

model Alert {
  id        Int        @id @default(autoincrement())
  type      alert_type
  message   String
  resolved  Boolean    @default(false)
  productId Int?
  userId    Int?
  createdAt DateTime   @default(now())

  @@map("alert")
}

// ── IP Whitelist ──────────────────────────────────────────────────────────────

model IpWhitelistEntry {
  id        Int      @id @default(autoincrement())
  ip        String   @unique(map: "IpWhitelistEntry_ip_key")
  label     String?
  createdAt DateTime @default(now())

  @@map("ipwhitelistentry")
}

// ── Products ──────────────────────────────────────────────────────────────────

model Product {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  sku         String   @unique(map: "sku") @db.VarChar(100)
  name        String   @map("nombre") @db.VarChar(255)
  description String?  @map("descripcion") @db.Text
  price       Decimal  @default(0.00) @map("precio_base") @db.Decimal(10, 2)
  stock       Int      @default(0) @map("stock_total")
  minStock    Int      @default(5)
  asin        String?  @db.VarChar(255)
  activo      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @db.Timestamp(0)

  order_items       order_items[]
  platform_products platform_products[]

  @@map("products")
}

// ── Platforms ─────────────────────────────────────────────────────────────────

model Platform {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  nombre     String   @db.VarChar(100)
  slug       String   @unique(map: "slug") @db.VarChar(50)
  api_key    String?  @db.VarChar(255)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  orders            Order[]
  platform_products platform_products[]

  @@map("platforms")
}

// ── Customers ─────────────────────────────────────────────────────────────────

model Customer {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  nombre     String   @unique @db.VarChar(255)
  email      String?  @db.VarChar(255)
  telefono   String?  @db.VarChar(30)
  direccion  String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  orders Order[]

  @@map("customers")
}

// ── Orders ────────────────────────────────────────────────────────────────────

model Order {
  id              Int           @id @default(autoincrement()) @db.UnsignedInt
  platformId      Int           @map("platform_id") @db.UnsignedInt
  customerId      Int           @map("customer_id") @db.UnsignedInt
  externalOrderId String        @map("external_order_id") @db.VarChar(255)
  estado          orders_estado @default(pendiente)
  total           Decimal       @default(0.00) @db.Decimal(10, 2)
  fechaPedido     DateTime      @default(now()) @map("fecha_pedido") @db.Timestamp(0)
  created_at      DateTime      @default(now()) @db.Timestamp(0)
  updated_at      DateTime      @default(now()) @db.Timestamp(0)

  customer    Customer      @relation(fields: [customerId], references: [id], onUpdate: Restrict, map: "fk_order_customer")
  platform    Platform      @relation(fields: [platformId], references: [id], onUpdate: Restrict, map: "fk_order_platform")
  invoices    invoices?
  order_items order_items[]

  @@unique([platformId, externalOrderId], map: "uq_external_order")
  @@index([customerId], map: "fk_order_customer")
  @@map("orders")
}

// ── Order Items ───────────────────────────────────────────────────────────────

model order_items {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  order_id        Int      @db.UnsignedInt
  product_id      Int      @db.UnsignedInt
  cantidad        Int      @default(1)
  precio_unitario Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  created_at      DateTime @default(now()) @db.Timestamp(0)

  orders   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_item_order")
  products Product @relation(fields: [product_id], references: [id], onUpdate: Restrict, map: "fk_item_product")

  @@index([order_id], map: "fk_item_order")
  @@index([product_id], map: "fk_item_product")
}

// ── Platform Products ─────────────────────────────────────────────────────────

model platform_products {
  id                Int      @id @default(autoincrement()) @db.UnsignedInt
  product_id        Int      @db.UnsignedInt
  platform_id       Int      @db.UnsignedInt
  external_id       String   @db.VarChar(255)
  precio_plataforma Decimal  @default(0.00) @db.Decimal(10, 2)
  stock_reservado   Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamp(0)
  updated_at        DateTime @default(now()) @db.Timestamp(0)

  platforms Platform @relation(fields: [platform_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_pp_platform")
  products  Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_pp_product")

  @@unique([product_id, platform_id], map: "uq_product_platform")
  @@index([platform_id], map: "fk_pp_platform")
}

// ── Invoices ──────────────────────────────────────────────────────────────────

model invoices {
  id             Int             @id @default(autoincrement()) @db.UnsignedInt
  order_id       Int             @unique(map: "order_id") @db.UnsignedInt
  numero_factura String          @unique(map: "numero_factura") @db.VarChar(50)
  total          Decimal         @db.Decimal(10, 2)
  estado         invoices_estado @default(pendiente)
  fecha_emision  DateTime        @default(now()) @db.Timestamp(0)
  created_at     DateTime        @default(now()) @db.Timestamp(0)
  updated_at     DateTime        @default(now()) @db.Timestamp(0)

  orders Order @relation(fields: [order_id], references: [id], onUpdate: Restrict, map: "fk_invoice_order")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum user_role {
  ADMIN
  MANAGER
  VIEWER
}

enum log_level {
  INFO
  WARN
  ERROR
}

enum alert_type {
  LOW_STOCK
  AMAZON_ERROR
  LOGIN_FAILED
  WORKER_ERROR
}

enum orders_estado {
  pendiente
  confirmado
  enviado
  entregado
  cancelado
}

enum invoices_estado {
  pendiente
  emitida
  pagada
  anulada
}
